#!/usr/bin/env node
/**
 * Claude Code UserPromptSubmit Hook - Message Logger
 * Logs user messages for reference and compaction-proof history.
 */

import * as fs from 'fs/promises';
import * as path from 'path';

const LOG_FILE = path.join(process.cwd(), '.claude', 'user-prompts.csv');

let input = '';
process.stdin.setEncoding('utf8');
for await (const chunk of process.stdin) {
  input += chunk;
}

try {
  const data = JSON.parse(input);
  const prompt = data.prompt?.trim();

  if (prompt && prompt.length >= 10 && !prompt.startsWith('/')) {
    const timestamp = Math.floor(Date.now() / 1000);
    // CSV escape: double up quotes and wrap in quotes
    const escapedPrompt = `"${prompt.replace(/"/g, '""')}"`;
    const entry = `${timestamp},${escapedPrompt}\n`;

    await fs.mkdir(path.dirname(LOG_FILE), { recursive: true });

    try {
      await fs.access(LOG_FILE);
    } catch {
      // File doesn't exist, write header
      await fs.writeFile(LOG_FILE, 'timestamp,prompt\n');
    }

    await fs.appendFile(LOG_FILE, entry);
  }
} catch { }

process.exit(0);
