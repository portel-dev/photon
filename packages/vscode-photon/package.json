{
  "name": "photon-vscode",
  "displayName": "Photon",
  "description": "Photon authoring support for .photon.ts files",
  "version": "0.0.1",
  "publisher": "portel-dev",
  "private": true,
  "license": "MIT",
  "keywords": [
    "photon",
    "typescript",
    "mcp",
    "beam",
    "vscode"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/portel-dev/photon.git"
  },
  "homepage": "https://github.com/portel-dev/photon",
  "bugs": {
    "url": "https://github.com/portel-dev/photon/issues"
  },
  "scripts": {
    "build": "node ./scripts/build.cjs",
    "check": "node -c ./extension.cjs",
    "smoke": "npm run check && npm run build && node ./scripts/smoke.cjs",
    "regression": "npm run smoke && node ./scripts/regression.cjs",
    "package": "npm run build && npx @vscode/vsce package --allow-missing-repository",
    "vscode:prepublish": "npm run build"
  },
  "files": [
    "extension.cjs",
    "README.md",
    "package.json",
    ".generated/**",
    ".vscode/**"
  ],
  "dependencies": {
    "typescript": "^5.7.3"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onCommand:photon.openInBeam",
    "onCommand:photon.regenerateEditorCache",
    "onCommand:photon.createPhoton",
    "onCommand:photon.goToSymbol"
  ],
  "main": "./extension.cjs",
  "contributes": {
    "commands": [
      {
        "command": "photon.openInBeam",
        "title": "Photon: Open In Beam"
      },
      {
        "command": "photon.regenerateEditorCache",
        "title": "Photon: Regenerate Editor Cache"
      },
      {
        "command": "photon.createPhoton",
        "title": "Photon: Create Photon"
      },
      {
        "command": "photon.goToSymbol",
        "title": "Photon: Go To Photon Symbol"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "photon.openInBeam",
          "when": "resourceExtname == .ts && resourceFilename =~ /.*\\.photon\\.ts$/",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "photon.openInBeam",
          "when": "resourceExtname == .ts && resourceFilename =~ /.*\\.photon\\.ts$/"
        },
        {
          "command": "photon.goToSymbol",
          "when": "resourceExtname == .ts && resourceFilename =~ /.*\\.photon\\.ts$/"
        }
      ]
    },
    "configuration": {
      "title": "Photon",
      "properties": {
        "photon.beamUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Beam base URL used by the Open In Beam command."
        }
      }
    }
  }
}
