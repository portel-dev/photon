{
  "git": {
    "commitMessage": "chore: release v${version}\n\nConstraint: release-it owns package version, changelog, tag, npm publish, and GitHub release steps.\nConfidence: high\nScope-risk: narrow\nDirective: Keep release commits mechanical; put product rationale in the preceding feature or fix commits.\nTested: release-it pre-release checks\nNot-tested: Manual post-publish install before this commit is created",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true,
    "requireUpstream": true,
    "requireCommits": true,
    "addUntrackedFiles": false
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": true,
    "skipChecks": true,
    "publishPackageManager": "bun",
    "publishPath": false,
    "versionArgs": "--no-package-lock"
  },
  "hooks": {
    "before:init": ["bash scripts/pre-release-check.sh"],
    "after:bump": ["bun run build"],
    "after:release": "echo Successfully released ${name} v${version} to ${repo.repository}"
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          {"type": "feat", "section": "Features"},
          {"type": "fix", "section": "Bug Fixes"},
          {"type": "chore", "hidden": true},
          {"type": "docs", "hidden": true},
          {"type": "style", "hidden": true},
          {"type": "refactor", "hidden": true},
          {"type": "perf", "section": "Performance"},
          {"type": "test", "hidden": true}
        ]
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog"
    }
  }
}
